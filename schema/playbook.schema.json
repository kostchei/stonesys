{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stonesys/schema/playbook.schema.json",
  "title": "StoneSys Playbook",
  "type": "object",
  "required": ["id", "name", "concept", "chassis", "identity", "stats", "derived", "moves", "advancement"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string" },
    "concept": { "type": "string" },
    "duty": { "type": "string" },
    "chassis": {
      "type": "object",
      "required": ["resolution", "array", "statCap"],
      "additionalProperties": false,
      "description": "Genesys narrative dice. A stat (1-5) sets ability dice; having a move grants 1 skill rank (1 ability die upgraded to proficiency); GM sets difficulty. No skill list, minimal stat gain.",
      "properties": {
        "resolution": { "type": "string" },
        "array": { "type": "array", "items": { "type": "integer" }, "minItems": 6, "maxItems": 6 },
        "statCap": { "type": "integer" }
      }
    },
    "identity": {
      "type": "object",
      "required": ["names", "look"],
      "additionalProperties": false,
      "properties": {
        "names": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "look": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "options"],
            "additionalProperties": false,
            "properties": {
              "label": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" }, "minItems": 2 }
            }
          }
        }
      }
    },
    "stats": {
      "type": "object",
      "required": ["default", "swaps"],
      "additionalProperties": false,
      "properties": {
        "default": {
          "type": "object",
          "required": ["STR", "DEX", "CON", "INT", "WIS", "CHA"],
          "additionalProperties": false,
          "properties": {
            "STR": { "type": "integer", "minimum": 1, "maximum": 5 },
            "DEX": { "type": "integer", "minimum": 1, "maximum": 5 },
            "CON": { "type": "integer", "minimum": 1, "maximum": 5 },
            "INT": { "type": "integer", "minimum": 1, "maximum": 5 },
            "WIS": { "type": "integer", "minimum": 1, "maximum": 5 },
            "CHA": { "type": "integer", "minimum": 1, "maximum": 5 }
          }
        },
        "anchor": {
          "type": ["object", "null"],
          "required": ["stat", "min"],
          "additionalProperties": false,
          "properties": {
            "stat": { "type": "string", "enum": ["STR", "DEX", "CON", "INT", "WIS", "CHA"] },
            "min": { "type": "integer", "minimum": 1, "maximum": 5 }
          }
        },
        "swaps": { "type": "integer", "minimum": 0 }
      }
    },
    "derived": {
      "type": "object",
      "required": ["hp", "damage", "load"],
      "additionalProperties": false,
      "properties": {
        "hp": { "type": "string" },
        "damage": { "type": "string" },
        "load": { "type": "string" }
      }
    },
    "gear": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "options"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "options": { "type": "array", "items": { "type": "string" }, "minItems": 2 }
        }
      }
    },
    "moves": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "trigger"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["signature", "fixed", "choice"] },
          "trigger": { "type": "string" },
          "stat": { "type": "string", "enum": ["STR", "DEX", "CON", "INT", "WIS", "CHA"] },
          "trained": { "type": "boolean", "description": "True if acting through this move grants the 1-rank proficiency upgrade. Defaults true for rollable moves." },
          "difficulty": { "type": "string", "enum": ["simple", "easy", "average", "hard", "daunting"], "description": "Default task difficulty (1-4 purple; 'simple' only for riskless chores); the GM may adjust per fiction." },
          "results": {
            "type": "object",
            "required": ["success"],
            "additionalProperties": false,
            "description": "Genesys-form outcome. success/failure are the basic axis; advantage/threat are spend menus; triumph/despair are big swings.",
            "properties": {
              "success": { "type": "string" },
              "failure": { "type": "string" },
              "advantage": { "type": "array", "items": { "type": "string" } },
              "threat": { "type": "array", "items": { "type": "string" } },
              "triumph": { "type": "string" },
              "despair": { "type": "string" }
            }
          },
          "hold": {
            "type": "object",
            "required": ["name", "spend"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "spend": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
            }
          },
          "text": { "type": "string" }
        }
      }
    },
    "embedment": {
      "type": "object",
      "required": ["bonds", "communityTie"],
      "additionalProperties": false,
      "description": "Layer 2. `system` is a freeform setting label (e.g. 'village' for vanilla Stonetop, or 'patron'/'god'/'bastion' for StoneSys). `start` and the matching `tracks` are optional, present only when a setting adds power-structure tracks.",
      "properties": {
        "system": { "type": "string" },
        "start": { "type": "object" },
        "bonds": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "communityTie": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "tracks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "min", "max", "start"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "min": { "type": "integer" },
          "max": { "type": "integer" },
          "start": { "type": "integer" },
          "note": { "type": "string" }
        }
      }
    },
    "advancement": {
      "type": "object",
      "required": ["basic", "advanced"],
      "additionalProperties": false,
      "properties": {
        "basic": { "type": "array", "items": { "type": "string" } },
        "advanced": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
