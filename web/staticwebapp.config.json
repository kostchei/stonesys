{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/playbooks/*.json", "/wiki/*", "/*.js", "/*.css", "/*.html"]
  },
  "routes": [
    {
      "route": "/web",
      "redirect": "/index.html",
      "statusCode": 302
    }
  ],
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "same-origin"
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
